
# .env.example — commit this file
# .env.local  — never commit, copy from this file

# ── CLERK AUTHENTICATION ─────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Dashboard → Webhooks: subscribe at least organization.created, organizationMembership.created,
# organizationMembership.updated (syncs Prisma `OrgMember.role` with Clerk).
CLERK_WEBHOOK_SECRET=whsec_...
# Clerk Dashboard → Paths (or User & authentication): allow redirects to your app after org invites,
# e.g. http://localhost:3000/post-auth and https://<production-domain>/post-auth — or patterns your
# Clerk instance supports. Missing entries cause "cannot redirect to your application" after invite.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ── DATABASE ─────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=verify-full"

# ── ENCRYPTION ───────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters (32 bytes). Store in 1Password.
ENCRYPTION_KEY=

# ── AWS ──────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=cyberguardintel-evidence-prod
# Optional for local evidence uploads; if omitted, the app falls back to the
# repo-standard alias ARN for the current AWS account:
# arn:aws:kms:<region>:<account-id>:alias/cyberguardintel-evidence-prod
KMS_KEY_ID=

# ── AI SERVICE ───────────────────────────────────────────────────
# Public URL of the FastAPI app (cyberguardintel-ai), not the Next.js app.
# Sanity check: GET ${AI_SERVICE_URL}/health must return JSON like {"status":"ok","model":"..."}.
# If you see plain text "OK" or ASCII art, the hostname is Railway's placeholder or the wrong service —
# use Railway → your Python service → Networking → generate/copy the real deployment URL.
AI_SERVICE_URL=https://your-fastapi-service.up.railway.app
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_KEY=

# ── UPSTASH REDIS (BullMQ job queue) ─────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── EMAIL ────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
FROM_EMAIL=compliance@cyberguardintel.ai

# ── STRIPE ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_GROWTH_PRICE_ID=price_...
STRIPE_BUSINESS_PRICE_ID=price_...

# ── APP CONFIG ───────────────────────────────────────────────────
# Must match the same origin you allow in Clerk for invite redirects (see CLERK notes above).
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@o0.ingest.sentry.io/0
